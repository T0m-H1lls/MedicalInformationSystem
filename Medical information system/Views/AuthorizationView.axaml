<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodel="clr-namespace:Medical_information_system.ViewModels"
        x:DataType="viewmodel:AuthorizationViewModel"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Medical_information_system.Views.AuthorizationView">
        
        <StackPanel HorizontalAlignment="Center" Spacing="15">
                <Label FontSize="20" FontWeight="Bold" HorizontalAlignment="Center">АВТОРИЗАЦИЯ</Label>
                <TextBox Watermark="Логин" Width="200"/>
                <TextBox Watermark="Пароль" Width="200"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text ="Нет аккаунта?"/>
                        <HyperlinkButton Content="Регистрация" Command="{Binding }"/>
                </StackPanel>
        </StackPanel>
    
</UserControl>
