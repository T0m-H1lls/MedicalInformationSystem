<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Medical_information_system.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="viewModels:StatisticPageViewModel"
             x:Class="Medical_information_system.Views.StatisticPageView">
    <StackPanel>
        <TextBlock Text=""/>
        <TextBlock Text=""/>
        <Button Command="{Binding GenerateStatisticsFromToExelCommand}" Content="Импортировать"/>
    </StackPanel>
</UserControl>
