<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodel="clr-namespace:Medical_information_system.ViewModels"
             x:DataType="viewmodel:MedicalRecordsPageViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Medical_information_system.Views.MedicalRecordsPageView">
    <Grid RowDefinitions="Auto Auto *" ColumnDefinitions="* Auto">
        <StackPanel Spacing="8" Orientation="Horizontal">
            <Button Classes="add" Content="+" 
                    Command="{Binding OpenAddMedicalRecordCommand}" 
                    IsVisible="{Binding }"/>
            <Button Classes="delete" Content="Удалить"  
                    Command="{Binding DeleteMedicalRecordCommand}" />
            <Button Classes="edit" Content="Изменить" 
                    Command="{Binding SwitchViewCommand}" />
            <TextBox VerticalAlignment="Center" Width="300" Watermark="Поиск" HorizontalContentAlignment="Center"
                     Margin="10"
                     Foreground="Black" Text="{Binding SearchText}" />
        </StackPanel>
        <Border Grid.Row="1"
                Grid.Column="1"
                Width="300"
                Background="White"
                Classes="medCard"
                IsVisible="{Binding ViewStyle}">
            <StackPanel>
                <StackPanel>
                    <ComboBox ItemsSource="{Binding PatientsList}"
                              SelectedItem="{Binding SelectedPatient}" Width="180">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FullName}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    
                    <Label Content="Диагноз"/>
                    <TextBox  Text="{Binding  DiagnoseEdit}"/>
                    
                    <Label Content="Описание"/>
                    <TextBox Text="{Binding  DescriptionEdit}"/>
                    
                    <Label Content="Дата"/>
                    <DatePicker SelectedDate="{Binding RecordDateEdit}"/>
                    
                    <Label Content="Лекарство"/>
                    <TextBox Text="{Binding MedicineEdit}"/>
                    
                </StackPanel>
               <StackPanel Orientation="Horizontal">
                    <Button Content="X"
                            HorizontalAlignment="Right"
                            Command="{Binding ClosePanelCommand}"
                            Classes="delete"/>
                    <Button Content="Сохранить"
                            Command="{Binding SaveEditCommand}" 
                            Classes="add"/>
               </StackPanel>
              
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="1" ItemsSource="{Binding MedicalRecordsList}"
                  AreRowDetailsFrozen="True"
                  GridLinesVisibility="All"
                  IsReadOnly="True"
                  BorderThickness="1"
                  BorderBrush="Black"
                  AutoGenerateColumns="False"
                  SelectedItem="{Binding SelectedMedicalRecord}">
            <DataGrid.Styles>
                <Style Selector="TextBlock">
                    <Setter Property="TextWrapping" Value="WrapWithOverflow" />
                </Style>
            </DataGrid.Styles>
            <DataGrid.Columns >
                <DataGridTextColumn Header="ФИО пациента" Binding="{Binding PatientName}"/>
                <DataGridTextColumn Header="ФИО врача" Binding="{Binding DoctorName}"/>
                <DataGridTextColumn Header="Диагноз" Binding="{Binding DiagnoseName}"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="200"/>
                <DataGridTextColumn Header="Лекарство" Binding="{Binding MedicineName}"/>
                <DataGridTextColumn Header="Дата посещения" Binding="{Binding RecordDate}"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="&lt;&lt;" Command="{Binding ShowFirstPageCommand}"/>
            <Button Content="&lt;" Command="{Binding ShowPrevPageCommand}"/>
            <Label Content="{Binding PageInfo}"/>
            <Button Content="&gt;" Command="{Binding ShowNextPageCommand}"/>
            <Button Content="&gt;&gt;" Command="{Binding ShowLastPageCommand}"/>
            <Label Content="Кол-во записей на странице:"/>
            <ComboBox ItemsSource="{Binding PageSizes}"
                      SelectedItem="{Binding CurrentPageSize}"/>
        </StackPanel>
    </Grid>
</UserControl>
