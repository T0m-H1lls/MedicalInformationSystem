<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodel="clr-namespace:Medical_information_system.ViewModels"
             x:DataType="viewmodel:MedicalRecordsPageViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Medical_information_system.Views.MedicalRecordsPageView">
    <Grid RowDefinitions="Auto *" ColumnDefinitions="* Auto">
        <StackPanel Spacing="8" Orientation="Horizontal">
            <Button Classes="add" Content="+"  Command="{Binding OpenAddMedicalRecordCommand}" />
            <Button Classes="delete" Content="Удалить"  Command="{Binding DeleteMedicalRecordCommand}" />
            <Button Classes="edit" Content="Изменить" Command="{Binding EditMedicalRecordCommand}" />
            <TextBox VerticalAlignment="Center" Width="300" Watermark="Поиск" HorizontalContentAlignment="Center"
                     Margin="10"
                     Foreground="Black" Text="{Binding SearchText}" />
        </StackPanel>
        <Border Grid.Row="1"
                Grid.Column="1"
                Width="300"
                Background="White"
                Classes="medCard"
                IsVisible="{Binding ViewStyle}">
            <StackPanel>
                <StackPanel>
                    <ComboBox ItemsSource="{Binding }"
                              SelectedItem="{Binding }" Width="180">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding }"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    
                    <Label Content="Диагноз"/>
                    <TextBox/>
                    
                    <Label Content="Описание"/>
                    <TextBox Text="{Binding }"/>
                    
                    <Label Content="Дата"/>
                    <DatePicker SelectedDate="{Binding}"/>
                    
                    <Label Content="Лекарство"/>
                    <TextBox Text="{Binding }"/>
                    
                </StackPanel>
               <StackPanel Orientation="Horizontal">
                    <Button Content="X"
                            HorizontalAlignment="Right"
                            Command="{Binding ClosePanelCommand}" />
                    <Button Content="Сохранить"
                            Command="{Binding SaveCommand}" />
               </StackPanel>
              
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="1" ItemsSource="{Binding MedicalRecordsList}"
                  AreRowDetailsFrozen="True"
                  GridLinesVisibility="All"
                  IsReadOnly="True"
                  BorderThickness="1"
                  BorderBrush="Black"
                  AutoGenerateColumns="False"
                  SelectedItem="{Binding }">
            <DataGrid.Styles>
                <Style Selector="TextBlock">
                    <Setter Property="TextWrapping" Value="WrapWithOverflow" />
                </Style>
            </DataGrid.Styles>
            <DataGrid.Columns >
                <DataGridTextColumn Header="ФИО пациента" Binding="{Binding PatientName}"/>
                <DataGridTextColumn Header="ФИО врача" Binding="{Binding DoctorName}"/>
                <DataGridTextColumn Header="Диагноз" Binding="{Binding DiagnoseName}"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="200"/>
                <DataGridTextColumn Header="Лекарство" Binding="{Binding MedicineName}"/>
                <DataGridTextColumn Header="Дата посещения" Binding="{Binding RecordDate}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
