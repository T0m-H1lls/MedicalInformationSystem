<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodel="clr-namespace:Medical_information_system.ViewModels"
             x:DataType="viewmodel:ApoitmentsPageViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Medical_information_system.Views.ApoitmentsPageView">
    <Grid RowDefinitions="Auto Auto *" ColumnDefinitions="* Auto">
        <StackPanel Spacing="8" Orientation="Horizontal">
            <Button Classes="add" Content="+"  Command="{Binding OpenAddAppointmentCommand}" />
            <Button Classes="delete" Content="Удалить"  Command="{Binding DeleteAppointmentCommand}" />
            <Button Classes="edit" Content="Изменить" Command="{Binding UpdateAppointmentCommand}" />
            <TextBox VerticalAlignment="Center" Width="300" Watermark="Поиск" HorizontalContentAlignment="Center"
                     Margin="10"
                     Foreground="Black" Text="{Binding SearchText}" />
        </StackPanel>
        <Border Grid.Row="1"
                Grid.Column="1"
                Width="380"
                Background="White"
                Classes="medCard"
                IsVisible="{Binding ViewStyle}">
            <StackPanel Spacing="10">
                <Label Content="Пациент"/>
                <ComboBox ItemsSource="{Binding PatientsList}"
                          SelectedItem="{Binding  SelectedPatientEdit}" Width="180">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding FullName}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                
                <Label Content="Дата"/>
                <DatePicker SelectedDate="{Binding EdAppointmentDate}"  Width="150"/>
                
                <Label Content="Статус"/>
                <ComboBox ItemsSource="{Binding StatusList}"
                          SelectedItem="{Binding SelectedStatusEdit}" Width="180">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                
                <Label Content="Направление к врачу"/> 
                <ComboBox ItemsSource="{Binding ReferralDoctorsList}"
                          SelectedItem="{Binding SelectedReferralDoctor}" Width="180">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding FullName}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                    <ComboBox.PlaceholderText>
                        Не выбрано
                    </ComboBox.PlaceholderText>
                </ComboBox>
                <Button Content="Очистить направление"
                        Command="{Binding ClearReferallCommand}" />
               
                <StackPanel Orientation="Horizontal">
                    <Button Content="X"
                            HorizontalAlignment="Right"
                            Command="{Binding ClosePanelCommand}" 
                            Classes="delete"/>
                    <Button Content="Сохранить"
                            Command="{Binding SaveEditCommand}" 
                            Classes="add"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="1" ItemsSource="{Binding AppointmentsList}"
                  AreRowDetailsFrozen="True"
                  GridLinesVisibility="All"
                  IsReadOnly="True"
                  BorderThickness="1"
                  BorderBrush="Black"
                  AutoGenerateColumns="False"
                  SelectedItem="{Binding SelectedAppointment}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ФИО пациента" Binding="{Binding PatientName}"/>
                <DataGridTextColumn Header="ФИО врача" Binding="{Binding DoctorFullName}"/>
                <DataGridTextColumn Header="Дата и время" Binding="{Binding AppointmentDate}"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}"/>
                <DataGridTextColumn Header="Направление к врачу" Binding="{Binding DocFullNameReferall}"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="&lt;&lt;" Command="{Binding ShowFirstPageCommand}"/>
            <Button Content="&lt;" Command="{Binding ShowPrevPageCommand}"/>
            <Label Content="{Binding PageInfo}"/>
            <Button Content="&gt;" Command="{Binding ShowNextPageCommand}"/>
            <Button Content="&gt;&gt;" Command="{Binding ShowLastPageCommand}"/>
            <Label Content="Кол-во записей на странице:"/>
            <ComboBox ItemsSource="{Binding PageSizes}"
                      SelectedItem="{Binding CurrentPageSize}"/>
        </StackPanel>
    </Grid>
</UserControl>
