<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodel="clr-namespace:Medical_information_system.ViewModels"
             x:DataType="viewmodel:ApoitmentsPageViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Medical_information_system.Views.ApoitmentsPageView">
    <Grid RowDefinitions="Auto *" ColumnDefinitions="* Auto">
        <StackPanel Spacing="8" Orientation="Horizontal">
            <Button Content="+" Background="LawnGreen" Command="{Binding OpenAddAppointmentCommand}" />
            <Button Content="Удалить" Background="Red" Command="{Binding DeleteAppointmentCommand}" />
            <Button Content="Изменить" Command="{Binding UpdateAppointmentCommand}" />
            <TextBox VerticalAlignment="Center" Width="300" Watermark="Поиск" HorizontalContentAlignment="Center"
                     Margin="10"
                     Foreground="Black" Text="{Binding SearchText}" />
        </StackPanel>
        <DataGrid Grid.Row="1" ItemsSource="{Binding AppointmentsList}"
                  AreRowDetailsFrozen="True"
                  GridLinesVisibility="All"
                  IsReadOnly="True"
                  BorderThickness="1"
                  BorderBrush="Black"
                  AutoGenerateColumns="False"
                  SelectedItem="{Binding }">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№"  Binding="{Binding Id}"/>
                <DataGridTextColumn Header="ФИО пациента" Binding="{Binding PatientName}"/>
                <DataGridTextColumn Header="ФИО врача" Binding="{Binding DoctorFullName}"/>
                <DataGridTextColumn Header="Дата и время" Binding="{Binding AppointmentDate}"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}"/>
                <DataGridTextColumn Header="Направление к врачу" Binding="{Binding DocFullNameReferall}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
