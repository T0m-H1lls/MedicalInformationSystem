<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodel="clr-namespace:Medical_information_system.ViewModels"
             x:DataType="viewmodel:DoctorsPageViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Medical_information_system.Views.DoctorsPageView">
    
    <DataGrid ItemsSource="{Binding Doctors}">
        <DataGrid.Columns>
            <DataGridTextColumn Header="№"  Binding="{Binding Id}"/>
            <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}"/>
            <DataGridTextColumn Header="Специализация" Binding="{Binding Speciality}"/>
            <DataGridTextColumn Header="Номер телефона" Binding="{Binding PhoneNumber}"/>
            <DataGridTextColumn Header="Кабинет" Binding="{Binding Room}"/>
            <DataGridTextColumn Header="Отделение" Binding="{Binding DepartmentName}"/>
        </DataGrid.Columns>
    </DataGrid>
</UserControl>
