<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodel="clr-namespace:Medical_information_system.ViewModels"
             x:DataType="viewmodel:MedicationsPageViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Medical_information_system.Views.MedicationsPageView">
    <DataGrid ItemsSource="{Binding MedicationList}">
        <DataGrid.Columns>
            <DataGridTextColumn Header="№"  Binding="{Binding Id}"/>
            <DataGridTextColumn Header="Название" Binding="{Binding Name}"/>
            <DataGridTextColumn Header="Производитель" Binding="{Binding Manufacturer}"/>
            <DataGridTextColumn Header="Описание" Binding="{Binding Description}"/>
        </DataGrid.Columns>
    </DataGrid>
</UserControl>
